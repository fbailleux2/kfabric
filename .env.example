KFABRIC_ENV=development
KFABRIC_APP_NAME=KFabric
KFABRIC_DATABASE_URL=sqlite:///./kfabric.db
KFABRIC_REDIS_URL=redis://localhost:6379/0
KFABRIC_RABBITMQ_URL=amqp://guest:guest@localhost:5672//
KFABRIC_QDRANT_URL=http://localhost:6333
KFABRIC_STORAGE_PATH=./storage
KFABRIC_API_KEY=
KFABRIC_ENABLE_METRICS=true
KFABRIC_ENABLE_MCP=true
KFABRIC_SECURE_MODE=true
KFABRIC_PREFER_CELERY_TASKS=true
KFABRIC_CELERY_ALWAYS_EAGER=false
KFABRIC_REMOTE_DISCOVERY_ENABLED=false
KFABRIC_REMOTE_COLLECTION_ENABLED=false
KFABRIC_MAX_FRAGMENT_CHARS=280
KFABRIC_ACCEPT_THRESHOLD=75
KFABRIC_SALVAGE_THRESHOLD=45
KFABRIC_SESSION_TTL_SECONDS=3600
